# =========================================================
# ENHANCED CUSTOMER SEGMENTATION PROJECT
# RFM + KMEANS + PCA + DBSCAN + COMPARISON
# =========================================================

# ---------------------------------------------------------
# 1) IMPORT LIBRARIES
# ---------------------------------------------------------
import pandas as pd
import numpy as np

import matplotlib.pyplot as plt
import seaborn as sns

from sklearn.preprocessing import RobustScaler
from sklearn.cluster import KMeans, DBSCAN
from sklearn.metrics import silhouette_score
from sklearn.decomposition import PCA
from sklearn.neighbors import NearestNeighbors


# ---------------------------------------------------------
# 2) LOAD DATASET
# ---------------------------------------------------------
df = pd.read_csv(r"Online Retail.csv")

print("=== FIRST 5 ROWS ===")
print(df.head())

print("\n=== DATASET INFO ===")
print(df.info())

print("\n=== DATASET SHAPE ===")
print(df.shape)


# ---------------------------------------------------------
# 3) BASIC INSPECTION
# ---------------------------------------------------------
print("\n=== MISSING VALUES ===")
print(df.isnull().sum())

print("\n=== DESCRIPTIVE STATISTICS ===")
print(df.describe())


# ---------------------------------------------------------
# 4) DATA CLEANING
# ---------------------------------------------------------

# remove missing customer IDs
df = df.dropna(subset=['CustomerID'])

# remove cancelled invoices
df = df[~df['InvoiceNo'].astype(str).str.startswith('C')]

# remove invalid values
df = df[df['Quantity'] > 0]
df = df[df['UnitPrice'] > 0]

# datatype conversion
df['CustomerID'] = df['CustomerID'].astype(int)
df['InvoiceDate'] = pd.to_datetime(
    df['InvoiceDate'],
    errors='coerce'
)

df = df.dropna(subset=['InvoiceDate'])

print("\n=== SHAPE AFTER CLEANING ===")
print(df.shape)


# ---------------------------------------------------------
# 5) FEATURE ENGINEERING
# ---------------------------------------------------------
df['TotalPrice'] = (
    df['Quantity'] *
    df['UnitPrice']
)

print(df.head())


# ---------------------------------------------------------
# 6) BUILD RFM TABLE
# ---------------------------------------------------------
analysis_date = (
    df['InvoiceDate'].max() +
    pd.Timedelta(days=1)
)

rfm = df.groupby('CustomerID').agg({

'InvoiceDate':lambda x:
(analysis_date - x.max()).days,

'InvoiceNo':'nunique',
'TotalPrice':'sum'

})

rfm.columns=[
'Recency',
'Frequency',
'Monetary'
]

print("\n=== RFM SAMPLE ===")
print(rfm.head())

print(rfm.describe())


# ---------------------------------------------------------
# 7) VISUALIZE ORIGINAL DISTRIBUTIONS
# ---------------------------------------------------------
for col in ['Recency','Frequency','Monetary']:

    plt.figure(figsize=(7,4))
    sns.histplot(
        rfm[col],
        bins=40,
        kde=True
    )
    plt.title(f'Original Distribution of {col}')
    plt.show()


# ---------------------------------------------------------
# 8) OUTLIER HANDLING (99% CAPPING)
# ---------------------------------------------------------
rfm_capped = rfm.copy()

for col in ['Recency','Frequency','Monetary']:

    upper_limit = (
      rfm_capped[col]
      .quantile(0.99)
    )

    rfm_capped[col] = np.where(
        rfm_capped[col] > upper_limit,
        upper_limit,
        rfm_capped[col]
    )

print(rfm_capped.describe())


# ---------------------------------------------------------
# 9) LOG TRANSFORMATION
# ---------------------------------------------------------
rfm_log = rfm_capped.copy()

for col in ['Recency','Frequency','Monetary']:
    rfm_log[col]=np.log1p(
        rfm_log[col]
    )


# ---------------------------------------------------------
# 10) VISUALIZE AFTER LOG
# ---------------------------------------------------------
for col in ['Recency','Frequency','Monetary']:

    plt.figure(figsize=(7,4))
    sns.histplot(
       rfm_log[col],
       bins=40,
       kde=True
    )

    plt.title(
      f'Log Distribution {col}'
    )
    plt.show()


# ---------------------------------------------------------
# 11) ROBUST SCALING
# ---------------------------------------------------------
scaler = RobustScaler()

rfm_scaled = scaler.fit_transform(
    rfm_log
)

rfm_scaled_df = pd.DataFrame(
rfm_scaled,
columns=['Recency','Frequency','Monetary'],
index=rfm.index
)


# ---------------------------------------------------------
# 12) ELBOW METHOD
# ---------------------------------------------------------
wcss=[]

for k in range(1,11):

    km=KMeans(
      n_clusters=k,
      random_state=42,
      n_init=10
    )

    km.fit(rfm_scaled_df)
    wcss.append(km.inertia_)

plt.plot(
range(1,11),
wcss,
marker='o'
)
plt.title('Elbow Method')
plt.show()


# ---------------------------------------------------------
# 13) SILHOUETTE FOR KMEANS
# ---------------------------------------------------------
scores=[]

for k in range(2,11):

    km=KMeans(
      n_clusters=k,
      random_state=42,
      n_init=10
    )

    labels=km.fit_predict(
      rfm_scaled_df
    )

    s=silhouette_score(
      rfm_scaled_df,
      labels
    )

    scores.append(s)

silhouette_table=pd.DataFrame({
'K':range(2,11),
'Silhouette':scores
})

print(silhouette_table)

plt.plot(
range(2,11),
scores,
marker='o'
)
plt.title('Silhouette Scores')
plt.show()


# ---------------------------------------------------------
# 14) FINAL KMEANS MODEL
# ---------------------------------------------------------
final_k=4

kmeans=KMeans(
n_clusters=final_k,
random_state=42,
n_init=10
)

rfm['Cluster']=kmeans.fit_predict(
rfm_scaled_df
)


# ---------------------------------------------------------
# 15) CLUSTER SUMMARY
# ---------------------------------------------------------
cluster_summary=(
rfm.groupby('Cluster')
.agg({
'Recency':'mean',
'Frequency':'mean',
'Monetary':'mean'
})
.round(2)
)

cluster_summary[
'Customer_Count'
]=rfm['Cluster'].value_counts()

print(cluster_summary)


# ---------------------------------------------------------
# 16) VISUALIZE CLUSTER PROFILES
# ---------------------------------------------------------
for col in ['Recency','Frequency','Monetary']:

 plt.figure(figsize=(8,5))
 sns.barplot(
 x=cluster_summary.index,
 y=cluster_summary[col]
 )
 plt.title(
 f'{col} by Cluster'
 )
 plt.show()


# ---------------------------------------------------------
# 17) SCATTER CLUSTER VISUALS
# ---------------------------------------------------------
plt.figure(figsize=(8,6))
sns.scatterplot(
x=rfm['Frequency'],
y=rfm['Monetary'],
hue=rfm['Cluster']
)
plt.show()


# =========================================================
# PCA IMPROVEMENTS
# =========================================================

# ---------------------------------------------------------
# 18) PCA REDUCTION
# ---------------------------------------------------------
pca=PCA(n_components=2)

rfm_pca=pca.fit_transform(
rfm_scaled_df
)

pca_df=pd.DataFrame(
rfm_pca,
columns=['PCA1','PCA2'],
index=rfm.index
)

pca_df['Cluster']=rfm['Cluster']

print(
'Explained Variance:',
pca.explained_variance_ratio_
)


# ---------------------------------------------------------
# 19) PCA VARIANCE PLOT
# ---------------------------------------------------------
plt.plot(
range(
1,
len(
pca.explained_variance_ratio_
)+1
),
np.cumsum(
pca.explained_variance_ratio_
),
marker='o'
)
plt.title(
'Cumulative Explained Variance'
)
plt.show()


# ---------------------------------------------------------
# 20) PCA VISUALIZATION
# ---------------------------------------------------------
plt.figure(figsize=(8,6))
sns.scatterplot(
x=pca_df['PCA1'],
y=pca_df['PCA2'],
hue=pca_df['Cluster']
)
plt.title('PCA Clusters')
plt.show()


# ---------------------------------------------------------
# 21) KMEANS BEFORE/AFTER PCA COMPARISON
# ---------------------------------------------------------
labels_original = KMeans(
n_clusters=4,
random_state=42
).fit_predict(
rfm_scaled_df
)

score_original=silhouette_score(
rfm_scaled_df,
labels_original
)

labels_pca=KMeans(
n_clusters=4,
random_state=42
).fit_predict(
rfm_pca
)

score_pca=silhouette_score(
rfm_pca,
labels_pca
)

print(
'KMeans Original:',
score_original
)

print(
'KMeans PCA:',
score_pca
)


# =========================================================
# DBSCAN OPTIMIZATION
# =========================================================

# ---------------------------------------------------------
# 22) K DISTANCE GRAPH
# ---------------------------------------------------------
neighbors=NearestNeighbors(
n_neighbors=5
)

fit=neighbors.fit(
rfm_scaled_df
)

distances,_=(
fit.kneighbors(
rfm_scaled_df
)
)

distances=np.sort(
distances[:,4]
)

plt.plot(distances)
plt.title(
'K Distance Graph'
)
plt.show()


# ---------------------------------------------------------
# 23) DBSCAN PARAMETER SEARCH
# ---------------------------------------------------------
print(
'\nDBSCAN GRID SEARCH'
)

best_score=-1
best_eps=None

for eps in [
0.3,
0.5,
0.7,
1.0
]:

 db=DBSCAN(
 eps=eps,
 min_samples=10
 )

 labels=db.fit_predict(
 rfm_scaled_df
 )

 valid_mask=(labels!=-1)

 if len(
 set(labels[valid_mask])
 )>1:

   score=silhouette_score(
   rfm_scaled_df[
   valid_mask
   ],
   labels[
   valid_mask
   ]
   )

   print(
   eps,
   score
   )

   if score>best_score:
      best_score=score
      best_eps=eps

print(
'Best eps:',
best_eps
)


# ---------------------------------------------------------
# 24) FINAL DBSCAN
# ---------------------------------------------------------
dbscan=DBSCAN(
eps=best_eps,
min_samples=10
)

db_labels=dbscan.fit_predict(
rfm_scaled_df
)

rfm[
'DBSCAN_Cluster'
]=db_labels

print(
pd.Series(
db_labels
).value_counts()
)


# ---------------------------------------------------------
# 25) DBSCAN SILHOUETTE
# ---------------------------------------------------------
valid=db_labels!=-1

if len(
set(
db_labels[valid]
)
)>1:

 dbscan_score=silhouette_score(
 rfm_scaled_df[
 valid
 ],
 db_labels[
 valid
 ]
 )

 print(
 'DBSCAN score:',
 dbscan_score
 )


# ---------------------------------------------------------
# 26) DBSCAN ON PCA
# ---------------------------------------------------------
dbscan_pca=DBSCAN(
eps=.5,
min_samples=8
)

pca_db_labels=(
dbscan_pca.fit_predict(
rfm_pca
)
)

plt.figure(figsize=(8,6))
sns.scatterplot(
x=pca_df['PCA1'],
y=pca_df['PCA2'],
hue=pca_db_labels
)
plt.title(
'DBSCAN on PCA'
)
plt.show()


# ---------------------------------------------------------
# 27) FINAL ALGORITHM COMPARISON
# ---------------------------------------------------------
comparison=pd.DataFrame({

'Algorithm':[
'KMeans Original',
'KMeans PCA',
'DBSCAN'
],

'Silhouette':[
score_original,
score_pca,
best_score
]

})

print(
'\nALGORITHM COMPARISON'
)
print(comparison)


# ---------------------------------------------------------
# 28) BUSINESS LABELS
# ---------------------------------------------------------
rec_med=(
cluster_summary[
'Recency'
].median()
)

freq_med=(
cluster_summary[
'Frequency'
].median()
)

mon_med=(
cluster_summary[
'Monetary'
].median()
)


def label_cluster(row):

 if (
 row['Recency']<=rec_med
 and
 row['Frequency']>=freq_med
 and
 row['Monetary']>=mon_med
 ):

   return (
   'High Value Loyal Customers'
   )

 elif(
 row['Recency']>rec_med
 and
 row['Frequency']<freq_med
 and
 row['Monetary']<mon_med
 ):

   return (
   'Inactive At Risk Customers'
   )

 elif(
 row['Monetary']>=mon_med
 and
 row['Frequency']<freq_med
 ):

   return(
   'High Spending Occasional'
   )

 else:

   return(
   'Growth Potential Customers'
   )


cluster_summary[
'Business_Label'
]=cluster_summary.apply(
label_cluster,
axis=1
)

print(cluster_summary)


# ---------------------------------------------------------
# 29) FINAL MERGE
# ---------------------------------------------------------
rfm_final=rfm.merge(
cluster_summary[[
'Business_Label'
]],
left_on='Cluster',
right_index=True,
how='left'
)

print(
rfm_final.head()
)


# ---------------------------------------------------------
# 30) EXPORT RESULTS
# ---------------------------------------------------------
rfm_final.to_csv(
'enhanced_customer_segmentation_results.csv',
index=True
)

cluster_summary.to_csv(
'enhanced_cluster_summary.csv',
index=True
)

comparison.to_csv(
'model_comparison.csv',
index=False
)

print(
'PROJECT COMPLETED SUCCESSFULLY'
)